// Cratedb — PostgreSQL via Prisma 7

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Application account (credentials + relations). Not to be confused with a public "profile" display.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile Profile?
  sessions Session[]
  records CollectionRecord[]

  @@index([email])
}

/// Optional display fields (1:1 with User). Separates auth identity from public profile data.
model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Opaque server-side session (cookie stores Session.id).
model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

/// Canonical owned release row (`title` = album title). Table name: records.
model CollectionRecord {
  id              String   @id @default(cuid())
  ownerId         String
  owner           User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  artist          String
  title           String
  year            Int?
  genre           String?
  storageLocation String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([ownerId])
  @@map("records")
}
