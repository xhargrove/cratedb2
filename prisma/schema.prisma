// Cratedb — PostgreSQL via Prisma 7

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Application account (credentials + relations). Not to be confused with a public "profile" display.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile Profile?
  sessions Session[]
  records          CollectionRecord[]
  singles          CollectionSingle[]
  twelveInchSingles CollectionTwelveInchSingle[]
  wantlistItems WantlistItem[]
  followsOutgoing UserFollow[] @relation("FollowOutgoing")
  followsIncoming UserFollow[] @relation("FollowIncoming")
  storageContainers StorageContainer[]

  @@index([email])
}

/// User-defined physical unit (shelf / box / crate) for organizing albums; optional image; QR points at live dashboard URL.
enum StorageContainerKind {
  SHELF
  BOX
  CRATE
}

model StorageContainer {
  id           String               @id @default(cuid())
  ownerId      String
  owner        User                 @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name         String
  kind         StorageContainerKind
  locationNote String?
  /// Relative object key: `{ownerId}/containers/{containerId}.{ext}` (optional custom image).
  imageKey       String?
  imageMimeType  String?
  imageUpdatedAt DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  records CollectionRecord[]

  @@index([ownerId])
  @@map("storage_containers")
}

/// Optional display fields (1:1 with User). Separates auth identity from public profile data.
model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName String?
  /// Short public introduction (shown on `/u/[id]`).
  bio         String?
  /// How this member describes themselves on the crate scene (collector, DJ, etc.).
  vibe        ProfileVibe @default(COLLECTOR)
  /// When false, `/u/[id]` hides collection rows (profile header may still show).
  collectionPublic Boolean @default(true)
  /// Relative path under ARTWORK_STORAGE_ROOT: `{userId}/profile.{ext}`
  profileImageKey       String?
  profileImageMimeType  String?
  profileImageUpdatedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum ProfileVibe {
  COLLECTOR
  DJ
  PRODUCER
  CURATOR
  ARCHIVIST
  LISTENER
}

/// Physical rack / crate / box assignment (structured); `storageLocation` holds a display string for search & facets.
enum PhysicalStorageKind {
  NONE
  SHELF
  CRATE
  BOX
}

/// Opaque server-side session (cookie stores Session.id).
model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

/// Canonical owned release row (`title` = album title). Table name: records.
model CollectionRecord {
  id              String   @id @default(cuid())
  ownerId         String
  owner           User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  artist          String
  title           String
  year            Int?
  genre           String?
  storageKind     PhysicalStorageKind @default(NONE)
  shelfRow        Int?
  shelfColumn     Int?
  crateNumber     Int?
  boxNumber       Int?
  boxCustomLabel  String?
  storageLocation String?
  notes           String?
  /// Relative path under local artwork storage root (`ARTWORK_STORAGE_ROOT`): `{ownerId}/{recordId}.{ext}`
  artworkKey      String?
  artworkMimeType String?
  artworkUpdatedAt DateTime?

  /// Last applied external metadata provider (e.g. `musicbrainz`).
  metadataSource       String?
  /// External release identifier (e.g. MusicBrainz release MBID).
  metadataSourceId     String?
  /// When enrichment was last applied to this row.
  metadataAppliedAt    DateTime?

  /// Spotify album id when the row was prefilled from search (optional).
  spotifyAlbumId       String?

  /// Number of physical copies owned (same pressing / listing).
  quantity Int @default(1)

  /// Optional physical container assignment (distinct from facet-oriented `storageKind` / shelf grid fields).
  containerId String?
  container   StorageContainer? @relation(fields: [containerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([containerId])
  @@map("records")
}

/// Owned **45 RPM single** — one row per physical single; `title` is the main song (A-side).
model CollectionSingle {
  id              String   @id @default(cuid())
  ownerId         String
  owner           User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  artist          String
  title           String
  /// Optional B-side song title.
  bSideTitle      String?
  year            Int?
  genre           String?
  storageKind     PhysicalStorageKind @default(NONE)
  shelfRow        Int?
  shelfColumn     Int?
  crateNumber     Int?
  boxNumber       Int?
  boxCustomLabel  String?
  storageLocation String?
  notes           String?
  /// Relative path: `{ownerId}/singles/{singleId}.{ext}`
  artworkKey      String?
  artworkMimeType String?
  artworkUpdatedAt DateTime?

  /// Spotify track id when prefilled from song search (optional).
  spotifyTrackId  String?

  /// Number of physical copies owned (same pressing / listing).
  quantity Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@map("collection_singles")
}

/// Owned **12-inch single** (maxi / extended) — same row shape as 45s; separate shelf category.
model CollectionTwelveInchSingle {
  id              String   @id @default(cuid())
  ownerId         String
  owner           User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  artist          String
  title           String
  /// Optional B-side song title.
  bSideTitle      String?
  year            Int?
  genre           String?
  storageKind     PhysicalStorageKind @default(NONE)
  shelfRow        Int?
  shelfColumn     Int?
  crateNumber     Int?
  boxNumber       Int?
  boxCustomLabel  String?
  storageLocation String?
  notes           String?
  /// Relative path: `{ownerId}/twelve-inch/{twelveInchId}.{ext}`
  artworkKey      String?
  artworkMimeType String?
  artworkUpdatedAt DateTime?

  /// Spotify track id when prefilled from song search (optional).
  spotifyTrackId  String?

  /// Number of physical copies owned (same pressing / listing).
  quantity Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@map("collection_twelve_inch_singles")
}

/// Desired release the user does not own yet — freeform metadata, separate from `CollectionRecord`.
model WantlistItem {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  artist    String
  title     String
  year      Int?
  genre     String?
  notes     String?
  /// Stable normalized key for duplicate prevention (see `buildWantlistDedupeKey`).
  dedupeKey String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ownerId, dedupeKey])
  @@index([ownerId])
  @@map("wantlist_items")
}

/// follower → followed (no self-follow; enforced in app + unique pair).
model UserFollow {
  id         String   @id @default(cuid())
  followerId String
  followedId String
  follower   User     @relation("FollowOutgoing", fields: [followerId], references: [id], onDelete: Cascade)
  followed   User     @relation("FollowIncoming", fields: [followedId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([followerId, followedId])
  @@index([followerId])
  @@index([followedId])
  @@map("user_follows")
}
