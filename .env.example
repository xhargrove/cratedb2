# Copy to `.env` or `.env.local` for local development.
# Next.js loads `.env.local` over `.env` when both exist.

# -----------------------------------------------------------------------------
# Required (database)
# -----------------------------------------------------------------------------

# PostgreSQL connection string (required whenever the app uses the database).
# If the password contains @ : / ? # & % etc., URL-encode those characters in the
# password segment only (or use the full string copied from your host dashboard).
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/cratedb?schema=public"

# Hosted Postgres often uses SSL. The app normalizes legacy `sslmode=require`
# (and similar) to `verify-full` for the Prisma/pg pool so Node/pg v8 does not
# spam deprecation warnings. You can still set `sslmode=verify-full` yourself.
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/db?schema=public&sslmode=verify-full"

# -----------------------------------------------------------------------------
# Optional — logging & Prisma
# -----------------------------------------------------------------------------

# Pino log level: fatal | error | warn | info | debug | trace | silent
# LOG_LEVEL=info

# Set to "true" to log Prisma SQL in development (default: warn/error only).
# PRISMA_QUERY_LOG=true

# -----------------------------------------------------------------------------
# Optional — artwork (local filesystem, albums + 45s)
# -----------------------------------------------------------------------------

# Single root for all cover art. Album keys: {ownerId}/{recordId}.{ext}
# Single keys: {ownerId}/singles/{singleId}.{ext} — same volume, no separate var.
# Default: <process cwd>/storage/artwork (see getArtworkStorageRoot in code). The
# process cwd in production is whatever your host uses (often the app root); do
# not assume a developer’s laptop path.
# REQUIRED in production if you need artwork to survive restarts: a persistent
# disk or mount. Ephemeral container filesystems lose files on every deploy.
# ARTWORK_STORAGE_ROOT=/var/lib/cratedb/artwork

# -----------------------------------------------------------------------------
# Optional — Spotify album search (client credentials)
# Create https://developer.spotify.com/dashboard application → Client ID + secret.
# Core CRUD works without these; search panel shows "unavailable" when unset.
# -----------------------------------------------------------------------------

# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Optional — metadata enrichment (MusicBrainz)
# Off unless ENRICHMENT_ENABLED=true. Core CRUD does not require these.
# -----------------------------------------------------------------------------

# ENRICHMENT_ENABLED=true
# MUSICBRAINZ_CONTACT="you@example.com"
# Optional full User-Agent header for MusicBrainz API etiquette:
# MUSICBRAINZ_USER_AGENT="MyApp/1.0 (+https://example.com) you@example.com"

# -----------------------------------------------------------------------------
# Optional — Figma Code Connect (design ↔ code in Dev Mode)
# -----------------------------------------------------------------------------

# Personal access token with access to your Figma files/libraries.
# Used by `npm run figma:connect:publish` — not required for running the Next.js app.
# FIGMA_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# Notes
# -----------------------------------------------------------------------------

# NODE_ENV is normally set by Next.js / your process manager (development | production | test).
# LOG_LEVEL and DATABASE_URL are the primary optional/required knobs for local dev beyond Postgres.
