# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Local artwork uploads (Phase 5)
/storage/artwork

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env*.local

# Allow committed templates
!.env.example

# Cursor / local IDE
.cursor/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Prisma Client (generated by `prisma generate`, runs on postinstall)
/src/generated/prisma
